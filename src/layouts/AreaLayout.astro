---
import BaseLayout from './BaseLayout.astro';

interface Props {
  area: string;
  title: string;
  description: string;
}

const { area, title, description } = Astro.props;

const services = [
  { title: 'Απεντομώσεις', desc: 'Καταπολέμηση κατσαρίδων, κοριών, μυρμηγκιών και κάθε εντόμου.', href: '/ypiresies/apentomoseis/' },
  { title: 'Απολυμάνσεις', desc: 'Απολύμανση κατοικιών, γραφείων, εστιατορίων με πιστοποιημένα βιοκτόνα.', href: '/ypiresies/apolymansis/' },
  { title: 'Μυοκτονίες', desc: 'Δολωματικοί σταθμοί, παγίδες και σφράγιση σημείων εισόδου τρωκτικών.', href: '/ypiresies/myoktonies/' },
  { title: 'Βιολογικοί Καθαρισμοί', desc: 'Βαθύς καθαρισμός στρωμάτων, καναπέδων, μοκετών.', href: '/ypiresies/viologikoi-katharismoi/' },
];
---
<BaseLayout title={title} description={description}>
  <section class="area-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Αρχική</a>
        <span>/</span>
        <span>Περιοχές</span>
        <span>/</span>
        <span aria-current="page">{area}</span>
      </nav>
      <h1 class="area-hero-title">Απολυμάνσεις & Απεντομώσεις {area}</h1>
      <p class="area-hero-subtitle">
        Επαγγελματικές υπηρεσίες απεντομώσεων, απολυμάνσεων και βιολογικών καθαρισμών
        στην περιοχή {area}. Άμεση εξυπηρέτηση, πιστοποιημένοι τεχνικοί, οικολογικά σκευάσματα.
      </p>
      <div class="area-hero-actions">
        <a href="tel:+302101234567" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Καλέστε: 210 123 4567
        </a>
        <a href="/epikoinonia/" class="btn btn-outline btn-lg">Δωρεάν Εκτίμηση</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: var(--content-default)">
      <slot />
    </div>
  </section>

  <section class="section-sm" style="background: var(--color-surface-2)">
    <div class="container">
      <h2 class="section-title" style="text-align:center; margin-bottom: var(--space-10)">Υπηρεσίες στην {area}</h2>
      <div class="area-services-grid">
        {services.map(s => (
          <a href={s.href} class="area-service-card">
            <h3>{s.title} {area}</h3>
            <p>{s.desc}</p>
            <span class="service-link-text">Μάθετε Περισσότερα →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="service-cta-band">
    <div class="container">
      <div class="cta-band-inner">
        <div>
          <h2 class="cta-band-title">Χρειάζεστε απεντόμωση στην {area};</h2>
          <p class="cta-band-text">Καλέστε μας τώρα. Εξυπηρέτηση αυθημερόν.</p>
        </div>
        <a href="tel:+302101234567" class="btn btn-primary btn-lg" style="background:#fff;color:var(--color-primary)">210 123 4567</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .area-hero {
    padding-block: clamp(var(--space-12), 6vw, var(--space-20));
    background: linear-gradient(135deg, var(--color-bg), var(--color-surface-2), var(--color-secondary-light));
  }
  .breadcrumb {
    display: flex; align-items: center; gap: var(--space-2);
    font-size: var(--text-xs); color: var(--color-text-faint); margin-bottom: var(--space-6);
  }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary); }
  .area-hero-title { font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-4); max-width: 700px; }
  .area-hero-subtitle { font-size: var(--text-lg); color: var(--color-text-muted); line-height: 1.7; max-width: 600px; margin-bottom: var(--space-6); }
  .area-hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }

  .area-services-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .area-services-grid { grid-template-columns: repeat(2, 1fr); } }
  .area-service-card {
    padding: var(--space-6); background: var(--color-surface); border: 1px solid var(--color-divider);
    border-radius: var(--radius-xl); transition: all var(--transition-smooth); display: flex; flex-direction: column; gap: var(--space-3);
  }
  .area-service-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-lg); transform: translateY(-2px); }
  .area-service-card h3 { font-size: var(--text-lg); font-weight: 700; }
  .area-service-card p { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.7; flex: 1; }
  .service-link-text { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  .service-cta-band { padding-block: var(--space-12); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-active)); }
  .cta-band-inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-6); }
  .cta-band-title { font-size: var(--text-xl); font-weight: 800; color: #fff; }
  .cta-band-text { color: rgba(255,255,255,0.8); margin-top: var(--space-2); }
</style>
