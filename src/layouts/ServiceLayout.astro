---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  features: { title: string; desc: string }[];
  process: { step: string; title: string; desc: string }[];
  faqs: { q: string; a: string }[];
}

const { title, description, heroTitle, heroSubtitle, features, process, faqs } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <!-- Service Hero -->
  <section class="service-hero">
    <div class="container">
      <div class="service-hero-inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Αρχική</a>
          <span>/</span>
          <a href="/ypiresies/apentomoseis/">Υπηρεσίες</a>
          <span>/</span>
          <span aria-current="page">{title}</span>
        </nav>
        <h1 class="service-hero-title">{heroTitle}</h1>
        <p class="service-hero-subtitle">{heroSubtitle}</p>
        <div class="service-hero-actions">
          <a href="tel:+302101234567" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Καλέστε: 210 123 4567
          </a>
          <a href="/epikoinonia/" class="btn btn-outline btn-lg">Δωρεάν Εκτίμηση</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section">
    <div class="container service-content">
      <div class="service-main">
        <slot />
      </div>
    </div>
  </section>

  <!-- Features -->
  {features.length > 0 && (
    <section class="section-sm" style="background: var(--color-surface-2)">
      <div class="container">
        <h2 class="section-title" style="text-align:center; margin-bottom: var(--space-10)">Γιατί να μας επιλέξετε</h2>
        <div class="features-grid">
          {features.map(f => (
            <div class="feature-card reveal">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              <h3 class="feature-title">{f.title}</h3>
              <p class="feature-desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Process -->
  {process.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title" style="text-align:center; margin-bottom: var(--space-10)">Η Διαδικασία μας</h2>
        <div class="process-grid">
          {process.map(p => (
            <div class="process-step reveal">
              <span class="process-number">{p.step}</span>
              <h3 class="process-title">{p.title}</h3>
              <p class="process-desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faqs.length > 0 && (
    <section class="section-sm" style="background: var(--color-surface-2)">
      <div class="container" style="max-width: var(--content-default)">
        <h2 class="section-title" style="text-align:center; margin-bottom: var(--space-10)">Συχνές Ερωτήσεις</h2>
        <div class="faq-list">
          {faqs.map(faq => (
            <details class="faq-item">
              <summary class="faq-question">{faq.q}</summary>
              <p class="faq-answer">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Band -->
  <section class="service-cta-band">
    <div class="container">
      <div class="cta-band-inner">
        <div>
          <h2 class="cta-band-title">Χρειάζεστε {title.toLowerCase()};</h2>
          <p class="cta-band-text">Καλέστε μας τώρα ή ζητήστε δωρεάν εκτίμηση online.</p>
        </div>
        <div class="cta-band-actions">
          <a href="tel:+302101234567" class="btn btn-primary btn-lg">210 123 4567</a>
          <a href="/epikoinonia/" class="btn btn-outline btn-lg" style="border-color:#fff;color:#fff;">Επικοινωνία</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-hero {
    padding-block: clamp(var(--space-12), 6vw, var(--space-20));
    background: linear-gradient(135deg, var(--color-bg), var(--color-surface-2), var(--color-primary-light));
  }
  .service-hero-inner { max-width: 700px; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    margin-bottom: var(--space-6);
  }
  .breadcrumb a { color: var(--color-text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--color-primary); }
  .service-hero-title {
    font-size: var(--text-2xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }
  .service-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }
  .service-hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }

  .service-content { max-width: var(--content-default); margin-inline: auto; }
  .service-main { line-height: 1.8; color: var(--color-text-muted); }
  .service-main :global(h2) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }
  .service-main :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }
  .service-main :global(p) { margin-bottom: var(--space-4); }
  .service-main :global(ul) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-xl);
  }
  .feature-title { font-size: var(--text-base); font-weight: 700; }
  .feature-desc { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.7; }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) { .process-grid { grid-template-columns: repeat(4, 1fr); } }
  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: center;
  }
  .process-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin-inline: auto;
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--color-primary);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
  }
  .process-title { font-size: var(--text-base); font-weight: 700; }
  .process-desc { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.7; }

  .faq-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .faq-question {
    padding: var(--space-4) var(--space-5);
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: var(--text-lg);
    color: var(--color-primary);
    transition: transform var(--transition-fast);
  }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer {
    padding: 0 var(--space-5) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .service-cta-band {
    padding-block: var(--space-12);
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-active));
  }
  .cta-band-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .cta-band-title { font-size: var(--text-xl); font-weight: 800; color: #fff; }
  .cta-band-text { color: rgba(255,255,255,0.8); margin-top: var(--space-2); }
  .cta-band-actions { display: flex; gap: var(--space-4); }
  .cta-band-actions .btn-primary { background: #fff; color: var(--color-primary); }
</style>
