---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Ασφαλείς Δολωματικοί Σταθμοί', desc: 'Κλειδωμένοι σταθμοί που εμποδίζουν την πρόσβαση παιδιών και κατοικίδιων.' },
  { title: 'Σφράγιση Εισόδων', desc: 'Εντοπίζουμε και σφραγίζουμε κάθε πιθανή είσοδο τρωκτικών.' },
  { title: 'Πρόγραμμα Πρόληψης', desc: 'Τακτικοί έλεγχοι και αναπλήρωση δολωμάτων για μόνιμη προστασία.' },
];
const process = [
  { step: '01', title: 'Εντοπισμός', desc: 'Ανιχνεύουμε σημεία δραστηριότητας και διαδρομές τρωκτικών.' },
  { step: '02', title: 'Τοποθέτηση', desc: 'Εγκατάσταση δολωματικών σταθμών και μηχανικών παγίδων.' },
  { step: '03', title: 'Αποκλεισμός', desc: 'Σφράγιση οπών, ρωγμών, σωληνώσεων.' },
  { step: '04', title: 'Παρακολούθηση', desc: 'Μηνιαίος έλεγχος και συντήρηση σταθμών.' },
];
const faqs = [
  { q: 'Τα ποντίκια είναι επικίνδυνα;', a: 'Ναι. Μεταδίδουν ασθένειες (λεπτοσπείρωση, σαλμονέλα), ρυπαίνουν τρόφιμα και μπορούν να προκαλέσουν βραχυκυκλώματα δαγκώνοντας καλώδια.' },
  { q: 'Γιατί δεν πιάνονται με τις παγίδες του εμπορίου;', a: 'Τα ποντίκια μαθαίνουν γρήγορα να αποφεύγουν κοινές παγίδες. Οι επαγγελματικές μέθοδοι χρησιμοποιούν ειδικά δολώματα υψηλής ελκυστικότητας.' },
];
---
<ServiceLayout title="Καταπολέμηση Ποντικιών" description="Αποτελεσματική καταπολέμηση ποντικιών σε Πειραιά, Νίκαια. Δολωματικοί σταθμοί, σφράγιση εισόδων, πρόληψη." heroTitle="Καταπολέμηση Ποντικιών" heroSubtitle="Μόνιμη απαλλαγή από τρωκτικά με ασφαλείς δολωματικούς σταθμούς, σφράγιση εισόδων και πρόγραμμα πρόληψης." features={features} process={process} faqs={faqs}>
  <h2>Ολοκληρωμένη Μυοκτονία για Κατοικίες & Επιχειρήσεις</h2>
  <p>Τα ποντίκια και οι αρουραίοι αναπαράγονται ραγδαία — ένα ζευγάρι μπορεί να παράγει πάνω από 200 απογόνους τον χρόνο. Η έγκαιρη αντιμετώπιση είναι κρίσιμη.</p>
  <h3>Σημάδια Παρουσίας Ποντικιών</h3>
  <ul>
    <li>Κόπρανα (μικρά, σκούρα, σε μέγεθος κόκκου ρυζιού)</li>
    <li>Σημάδια δοντιών σε τρόφιμα, σακούλες, καλώδια</li>
    <li>Ήχοι ξυσίματος τη νύχτα, κυρίως σε τοίχους και ταβάνια</li>
    <li>Δυσάρεστη οσμή αμμωνίας από ούρα τρωκτικών</li>
  </ul>
</ServiceLayout>
