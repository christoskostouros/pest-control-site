---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const features = [
  { title: 'Πιστοποιημένα Σκευάσματα', desc: 'Χρησιμοποιούμε αποκλειστικά εγκεκριμένα βιοκτόνα από τον ΕΟΦ, ασφαλή για ανθρώπους και κατοικίδια.' },
  { title: 'Εγγύηση Αποτελέσματος', desc: 'Δωρεάν επανάληψη εφαρμογής εντός της περιόδου εγγύησης αν το πρόβλημα επιμείνει.' },
  { title: 'Στοχευμένη Αντιμετώπιση', desc: 'Εντοπίζουμε το είδος εντόμου και εφαρμόζουμε εξειδικευμένο πρωτόκολλο αντιμετώπισης.' },
  { title: 'Ελάχιστη Ενόχληση', desc: 'Τεχνικές μικροψεκασμού και gel που δεν απαιτούν εκκένωση του χώρου.' },
  { title: 'Γρήγορη Ανταπόκριση', desc: 'Αυθημερόν εξυπηρέτηση στις περισσότερες περιπτώσεις, ακόμα και το Σαββατοκύριακο.' },
  { title: 'Αναλυτική Αναφορά', desc: 'Μετά από κάθε επέμβαση λαμβάνετε πλήρη αναφορά με ευρήματα και οδηγίες πρόληψης.' },
];

const process = [
  { step: '01', title: 'Επικοινωνία', desc: 'Επικοινωνείτε μαζί μας και μας περιγράφετε το πρόβλημα.' },
  { step: '02', title: 'Αυτοψία', desc: 'Πραγματοποιούμε δωρεάν αυτοψία και αξιολόγηση του χώρου.' },
  { step: '03', title: 'Εφαρμογή', desc: 'Εφαρμόζουμε το κατάλληλο πρωτόκολλο απεντόμωσης.' },
  { step: '04', title: 'Παρακολούθηση', desc: 'Follow-up έλεγχος για διασφάλιση του αποτελέσματος.' },
];

const faqs = [
  { q: 'Πόσο ασφαλής είναι η απεντόμωση;', a: 'Χρησιμοποιούμε σκευάσματα εγκεκριμένα από τον ΕΟΦ, κατάλληλα για χρήση ακόμα και σε χώρους με παιδιά και κατοικίδια. Τα οικολογικά μας σκευάσματα είναι χαμηλής τοξικότητας και αποσυντίθενται γρήγορα.' },
  { q: 'Πόσο διαρκεί η διαδικασία;', a: 'Μια τυπική απεντόμωση κατοικίας ολοκληρώνεται σε 30-60 λεπτά, ανάλογα με το μέγεθος του χώρου και τον τύπο επέμβασης.' },
  { q: 'Χρειάζεται να αδειάσω το σπίτι;', a: 'Στις περισσότερες περιπτώσεις όχι. Με τεχνικές gel και μικροψεκασμού, μπορείτε να παραμείνετε στον χώρο σας. Θα σας ενημερώσουμε αν απαιτείται βραχεία απομάκρυνση.' },
  { q: 'Πόσο κοστίζει μια απεντόμωση;', a: 'Το κόστος εξαρτάται από το μέγεθος του χώρου και τον τύπο εντόμου. Προσφέρουμε δωρεάν εκτίμηση πριν από κάθε εργασία, χωρίς δέσμευση.' },
];
---
<ServiceLayout
  title="Απεντομώσεις"
  description="Επαγγελματικές υπηρεσίες απεντόμωσης σε Πειραιά, Νίκαια, Κορυδαλλό. Πιστοποιημένοι τεχνικοί, οικολογικά σκευάσματα, εγγύηση αποτελέσματος."
  heroTitle="Επαγγελματικές Απεντομώσεις"
  heroSubtitle="Αποτελεσματική αντιμετώπιση κάθε είδους εντόμου με πιστοποιημένες μεθόδους και οικολογικά σκευάσματα νέας γενιάς. Ασφάλεια για την οικογένειά σας."
  features={features}
  process={process}
  faqs={faqs}
>
  <h2>Ολοκληρωμένες Υπηρεσίες Απεντόμωσης</h2>
  <p>
    Η BioClean Pro παρέχει ολοκληρωμένες υπηρεσίες απεντόμωσης σε κατοικίες, επαγγελματικούς χώρους,
    εστιατόρια, ξενοδοχεία και δημόσιους οργανισμούς. Αντιμετωπίζουμε αποτελεσματικά κατσαρίδες,
    κοριούς, μυρμήγκια, ψύλλους, σκνίπες, σφήκες και κάθε είδος εντόμου.
  </p>

  <h3>Μέθοδοι Απεντόμωσης</h3>
  <p>
    Εφαρμόζουμε σύγχρονες τεχνικές που εξασφαλίζουν μέγιστη αποτελεσματικότητα με ελάχιστη
    ενόχληση:
  </p>
  <ul>
    <li><strong>Ψεκασμός με μικροσταγονίδια:</strong> Εξαιρετική κάλυψη ακόμα και σε δυσπρόσιτα σημεία</li>
    <li><strong>Εφαρμογή Gel:</strong> Ιδανικό για κατσαρίδες σε κουζίνες και εστιατόρια, χωρίς απομάκρυνση</li>
    <li><strong>Παγίδευση & Monitoring:</strong> Παρακολούθηση του πληθυσμού με εξειδικευμένες παγίδες</li>
    <li><strong>Θερμική Επεξεργασία:</strong> Για κοριούς κλίνης, χωρίς χημικά σκευάσματα</li>
  </ul>

  <h3>Είδη Εντόμων που Αντιμετωπίζουμε</h3>
  <p>
    Η εξειδίκευσή μας καλύπτει το πλήρες φάσμα εντόμων δημόσιας υγείας:
    κατσαρίδες (γερμανικές και αμερικανικές), κοριούς κλίνης, μυρμήγκια,
    ψύλλους, σκνίπες, μύγες, κουνούπια, σφήκες, σκόρους και ακάρεα.
    Κάθε είδος αντιμετωπίζεται με εξειδικευμένο πρωτόκολλο.
  </p>
</ServiceLayout>
