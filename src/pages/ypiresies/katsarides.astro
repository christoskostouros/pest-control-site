---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Gel Τεχνολογία', desc: 'Εφαρμογή gel υψηλής ελκυστικότητας σε κρίσιμα σημεία, χωρίς οσμή και χωρίς εκκένωση.' },
  { title: 'Αποτέλεσμα σε 48 Ώρες', desc: 'Ορατή μείωση πληθυσμού εντός 48 ωρών από την πρώτη εφαρμογή.' },
  { title: 'Μακροχρόνια Προστασία', desc: 'Η δράση του gel διαρκεί εβδομάδες, εξαλείφοντας ολόκληρη την αποικία.' },
];
const process = [
  { step: '01', title: 'Αναγνώριση', desc: 'Εντοπίζουμε είδος κατσαρίδας και πηγές τροφής/νερού.' },
  { step: '02', title: 'Εφαρμογή Gel', desc: 'Τοποθέτηση σε ρωγμές, αρμούς, κάτω από πάγκους.' },
  { step: '03', title: 'Monitoring', desc: 'Κολλητικές παγίδες για παρακολούθηση αποτελεσμάτων.' },
  { step: '04', title: 'Πρόληψη', desc: 'Οδηγίες υγιεινής και σφράγιση σημείων εισόδου.' },
];
const faqs = [
  { q: 'Πώς να φύγουν οι κατσαρίδες;', a: 'Ο πιο αποτελεσματικός τρόπος είναι ο επαγγελματικός ψεκασμός ή η εφαρμογή gel. Τα σπιτικά σκευάσματα σπάνια λύνουν το πρόβλημα οριστικά.' },
  { q: 'Οι κατσαρίδες μεταδίδουν ασθένειες;', a: 'Ναι. Μεταφέρουν βακτήρια (σαλμονέλα, E.coli), μυκοπλάσματα και αλλεργιογόνα που μπορούν να πυροδοτήσουν αλλεργίες και άσθμα.' },
  { q: 'Πόσο κοστίζει η καταπολέμηση κατσαρίδων;', a: 'Η τιμή εξαρτάται από τη μέθοδο (gel ή ψεκασμός) και το μέγεθος του χώρου. Ζητήστε δωρεάν εκτίμηση.' },
];
---
<ServiceLayout title="Καταπολέμηση Κατσαρίδων" description="Εξειδικευμένη καταπολέμηση κατσαρίδων με gel και μικροψεκασμό. Αποτέλεσμα σε 48 ώρες. Πειραιάς, Νίκαια, Κορυδαλλός." heroTitle="Καταπολέμηση Κατσαρίδων" heroSubtitle="Οριστική εξάλειψη κατσαρίδων με gel τεχνολογία και στοχευμένο μικροψεκασμό. Χωρίς οσμή, χωρίς εκκένωση." features={features} process={process} faqs={faqs}>
  <h2>Αντιμετώπιση Κατσαρίδων σε Κατοικίες & Επιχειρήσεις</h2>
  <p>Οι κατσαρίδες αποτελούν ένα από τα πιο συνηθισμένα προβλήματα σε αστικά περιβάλλοντα. Στην Ελλάδα απαντώνται κυρίως δύο είδη: η γερμανική κατσαρίδα (μικρή, ανοιχτόχρωμη, εσωτερικού χώρου) και η αμερικανική κατσαρίδα (μεγαλύτερη, σκούρη, εισέρχεται από αποχετεύσεις).</p>
  <h3>Γιατί να Επιλέξετε Επαγγελματική Αντιμετώπιση</h3>
  <p>Τα εμπορικά εντομοκτόνα σκοτώνουν μόνο τα ορατά έντομα. Δεν φτάνουν στις φωλιές, στα αυγά ή στα νεαρά άτομα που κρύβονται σε ρωγμές. Η επαγγελματική εφαρμογή gel και μικροψεκασμού εξαλείφει ολόκληρη την αποικία μέσω domino effect.</p>
</ServiceLayout>
