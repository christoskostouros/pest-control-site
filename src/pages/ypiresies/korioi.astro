---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Θερμική Επεξεργασία', desc: 'Εξόντωση κοριών σε όλα τα στάδια ζωής (αυγά, νύμφες, ενήλικα) με θερμοκρασία.' },
  { title: 'Χωρίς Χημικά', desc: 'Η θερμική μέθοδος δεν αφήνει χημικά κατάλοιπα στον χώρο σας.' },
  { title: 'Πλήρης Εξάλειψη', desc: 'Συνδυασμός μεθόδων για 100% αποτελεσματικότητα, ακόμα και σε βαριές μολύνσεις.' },
];
const process = [
  { step: '01', title: 'Έρευνα', desc: 'Ενδελεχής έλεγχος στρωμάτων, κεφαλαριών, ρωγμών.' },
  { step: '02', title: 'Θερμική Εφαρμογή', desc: 'Ανέβασμα θερμοκρασίας στους 55°C+ για εξόντωση.' },
  { step: '03', title: 'Χημική Συμπλήρωση', desc: 'Στοχευμένη εφαρμογή εντομοκτόνου σε κρίσιμα σημεία.' },
  { step: '04', title: 'Επανέλεγχος', desc: 'Μετά από 10-14 ημέρες, δωρεάν follow-up έλεγχος.' },
];
const faqs = [
  { q: 'Πώς καταλαβαίνω αν έχω κοριούς;', a: 'Τα κύρια σημάδια είναι: κόκκινα τσιμπήματα σε σειρά στο δέρμα, μικρά σκούρα στίγματα στο στρώμα (κόπρανα), κενά κελύφη νυμφών, και ένα γλυκό/ταγκό άρωμα στο δωμάτιο.' },
  { q: 'Πώς μεταδίδονται οι κοριοί;', a: 'Οι κοριοί μεταφέρονται μέσω αποσκευών, μεταχειρισμένων επίπλων, ρούχων. Δεν σχετίζονται με καθαριότητα — μπορεί να εμφανιστούν οπουδήποτε.' },
  { q: 'Πόσες εφαρμογές χρειάζονται;', a: 'Συνήθως 1-2 εφαρμογές αρκούν. Σε βαριές μολύνσεις μπορεί να χρειαστούν 3 εφαρμογές σε διάστημα 3-4 εβδομάδων.' },
];
---
<ServiceLayout title="Καταπολέμηση Κοριών" description="Εξειδικευμένη καταπολέμηση κοριών κλίνης με θερμική επεξεργασία. Πλήρης εξάλειψη σε Πειραιά, Νίκαια, Κορυδαλλό." heroTitle="Καταπολέμηση Κοριών Κλίνης" heroSubtitle="Οριστική εξάλειψη κοριών κλίνης με θερμική επεξεργασία και στοχευμένη χημική εφαρμογή. Χωρίς κατάλοιπα." features={features} process={process} faqs={faqs}>
  <h2>Εξειδικευμένη Αντιμετώπιση Κοριών Κλίνης</h2>
  <p>Οι κοριοί κλίνης (Cimex lectularius) είναι μικρά αιμομυζητικά έντομα που τρέφονται με ανθρώπινο αίμα τη νύχτα. Κρύβονται σε ραφές στρωμάτων, κεφαλάρια, ρωγμές τοίχων, πρίζες και πίσω από κάδρα.</p>
  <h3>Γιατί οι Κοριοί Κλίνης Χρειάζονται Ειδικό Χειρισμό</h3>
  <p>Οι κοριοί είναι εξαιρετικά ανθεκτικοί. Τα κοινά εντομοκτόνα δεν φτάνουν στα σημεία όπου κρύβονται, ενώ τα αυγά τους είναι ανθεκτικά στα περισσότερα χημικά. Μόνο ο συνδυασμός θερμικής και χημικής μεθόδου εγγυάται πλήρη εξάλειψη.</p>
</ServiceLayout>
