---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Βαθύς Καθαρισμός', desc: 'Αφαιρούμε σκόνη, ακάρεα, αλλεργιογόνα και λεκέδες σε βάθος.' },
  { title: 'Οικολογικά Προϊόντα', desc: 'Βιοδιασπώμενα καθαριστικά, ασφαλή για βρέφη και κατοικίδια.' },
  { title: 'Αποτέλεσμα Αυθημερόν', desc: 'Ο χώρος σας είναι έτοιμος για χρήση εντός λίγων ωρών.' },
];
const process = [
  { step: '01', title: 'Αξιολόγηση', desc: 'Εξετάζουμε τα υφάσματα και τον βαθμό ρύπανσης.' },
  { step: '02', title: 'Προεπεξεργασία', desc: 'Αφαιρούμε χοντρή σκόνη και κατεργαζόμαστε λεκέδες.' },
  { step: '03', title: 'Βαθύς Καθαρισμός', desc: 'Εφαρμογή βιολογικού καθαρισμού με εξειδικευμένο εξοπλισμό.' },
  { step: '04', title: 'Στέγνωμα', desc: 'Αναρρόφηση υγρασίας και αερισμός.' },
];
const faqs = [
  { q: 'Τι περιλαμβάνει ο βιολογικός καθαρισμός;', a: 'Περιλαμβάνει βαθύ καθαρισμό με injection-extraction τεχνολογία, αφαίρεση λεκέδων, αλλεργιογόνων, ακάρεων, βακτηρίων και δυσοσμιών.' },
  { q: 'Πότε στεγνώνει;', a: 'Τα στρώματα στεγνώνουν σε 3-5 ώρες, οι καναπέδες σε 4-6 ώρες ανάλογα με τις συνθήκες αερισμού.' },
  { q: 'Πόσο συχνά πρέπει να γίνεται;', a: 'Συνιστούμε βιολογικό καθαρισμό 1-2 φορές τον χρόνο, ή πιο συχνά αν υπάρχουν αλλεργίες.' },
];
---
<ServiceLayout title="Βιολογικοί Καθαρισμοί" description="Βιολογικός καθαρισμός στρωμάτων, καναπέδων, μοκετών σε Πειραιά. Αφαίρεση αλλεργιογόνων, ακάρεων, οικολογικά προϊόντα." heroTitle="Βιολογικοί Καθαρισμοί" heroSubtitle="Βαθύς καθαρισμός στρωμάτων, καναπέδων, χαλιών και μοκετών. Εξαλείψτε αλλεργιογόνα και ακάρεα με οικολογικές μεθόδους." features={features} process={process} faqs={faqs}>
  <h2>Υγιεινός Χώρος με Βιολογικό Καθαρισμό</h2>
  <p>Ο βιολογικός καθαρισμός αφαιρεί σε βάθος σκόνη, ακάρεα, αλλεργιογόνα, βακτήρια και δυσοσμίες από στρώματα, καναπέδες, χαλιά, μοκέτες και εσωτερικά αυτοκινήτων.</p>
  <h3>Τι Καθαρίζουμε</h3>
  <ul>
    <li><strong>Στρώματα:</strong> Αφαίρεση ακάρεων, ιδρώτα, λεκέδων</li>
    <li><strong>Καναπέδες & Πολυθρόνες:</strong> Βαθύς καθαρισμός υφάσματος ή δέρματος</li>
    <li><strong>Χαλιά & Μοκέτες:</strong> Αφαίρεση βαθιάς σκόνης και λεκέδων</li>
    <li><strong>Κουρτίνες:</strong> Καθαρισμός χωρίς αφαίρεση</li>
    <li><strong>Εσωτερικά Αυτοκινήτων:</strong> Πλήρης βιολογικός καθαρισμός καμπίνας</li>
  </ul>
</ServiceLayout>
