---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Ασφαλείς Μέθοδοι', desc: 'Δολωματικοί σταθμοί ασφαλείας που δεν θέτουν σε κίνδυνο παιδιά και κατοικίδια.' },
  { title: 'Μόνιμη Λύση', desc: 'Δεν αρκεί η θανάτωση. Σφραγίζουμε σημεία εισόδου και εγκαθιστούμε σύστημα πρόληψης.' },
  { title: 'Άμεση Εξυπηρέτηση', desc: 'Κατανοούμε πως τα ποντίκια αποτελούν επείγον ζήτημα υγιεινής.' },
];
const process = [
  { step: '01', title: 'Αυτοψία', desc: 'Εντοπισμός σημείων δραστηριότητας και εισόδου τρωκτικών.' },
  { step: '02', title: 'Σχέδιο Δράσης', desc: 'Τοποθέτηση δολωματικών σταθμών και παγίδων.' },
  { step: '03', title: 'Σφράγιση', desc: 'Κλείσιμο σημείων εισόδου για αποτροπή επανεμφάνισης.' },
  { step: '04', title: 'Monitoring', desc: 'Τακτικοί έλεγχοι για διασφάλιση καθαρού χώρου.' },
];
const faqs = [
  { q: 'Πώς καταλαβαίνω ότι έχω ποντίκια;', a: 'Σημάδια παρουσίας τρωκτικών περιλαμβάνουν: κόπρανα (μικρά σκούρα κουκίδια), σημάδια δοντιών σε τρόφιμα/καλώδια, ήχους τη νύχτα, και δυσάρεστη οσμή.' },
  { q: 'Τα δηλητήρια είναι επικίνδυνα;', a: 'Χρησιμοποιούμε κλειδωμένους δολωματικούς σταθμούς ασφαλείας. Μόνο τα τρωκτικά μπορούν να έχουν πρόσβαση στο δόλωμα.' },
  { q: 'Πόσο γρήγορα θα δω αποτέλεσμα;', a: 'Τα πρώτα αποτελέσματα φαίνονται σε 2-5 ημέρες. Η πλήρης εξάλειψη ολοκληρώνεται σε 1-3 εβδομάδες.' },
];
---
<ServiceLayout title="Μυοκτονίες" description="Επαγγελματική μυοκτονία σε Πειραιά και Δυτική Αττική. Δολωματικοί σταθμοί, παγίδες, σφράγιση σημείων εισόδου." heroTitle="Αποτελεσματική Μυοκτονία" heroSubtitle="Εξάλειψη τρωκτικών με ασφαλείς μεθόδους. Δολωματικοί σταθμοί, σφράγιση εισόδων και σύστημα πρόληψης." features={features} process={process} faqs={faqs}>
  <h2>Ολοκληρωμένη Αντιμετώπιση Τρωκτικών</h2>
  <p>Τα τρωκτικά (ποντίκια, αρουραίοι) αποτελούν σοβαρή απειλή για τη δημόσια υγεία. Μεταφέρουν ασθένειες, ρυπαίνουν τρόφιμα και προκαλούν υλικές ζημιές. Η BioClean Pro εφαρμόζει Ολοκληρωμένη Διαχείριση Τρωκτικών (IPM) που συνδυάζει εξάλειψη, αποκλεισμό και πρόληψη.</p>
  <h3>Μέθοδοι Μυοκτονίας</h3>
  <ul>
    <li><strong>Δολωματικοί Σταθμοί:</strong> Κλειδωμένοι σταθμοί ασφαλείας με τρωκτικοκτόνο δόλωμα</li>
    <li><strong>Μηχανικές Παγίδες:</strong> Για χώρους με ιδιαίτερες ανάγκες ασφαλείας</li>
    <li><strong>Αποκλεισμός Εισόδου:</strong> Σφράγιση ρωγμών, σωληνώσεων και σημείων πρόσβασης</li>
    <li><strong>Πρόγραμμα Monitoring:</strong> Τακτικός έλεγχος με ηλεκτρονικές παγίδες ανίχνευσης</li>
  </ul>
</ServiceLayout>
