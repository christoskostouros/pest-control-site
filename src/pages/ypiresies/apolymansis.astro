---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const features = [
  { title: 'Πιστοποιημένα Βιοκτόνα', desc: 'Χρησιμοποιούμε προϊόντα εγκεκριμένα από τον ΕΟΦ, αποτελεσματικά κατά μικροβίων και ιών.' },
  { title: 'Πλήρης Κάλυψη', desc: 'Απολύμανση δαπέδων, τοίχων, επιφανειών, κλιματισμών και αεραγωγών.' },
  { title: 'Γρήγορη Εξυπηρέτηση', desc: 'Αυθημερόν ανταπόκριση. Ιδανικό για καταστήματα, γραφεία και εστιατόρια.' },
];
const process = [
  { step: '01', title: 'Αξιολόγηση', desc: 'Καταγράφουμε τις ανάγκες του χώρου σας.' },
  { step: '02', title: 'Πρωτόκολλο', desc: 'Επιλέγουμε το κατάλληλο πρωτόκολλο απολύμανσης.' },
  { step: '03', title: 'Εφαρμογή', desc: 'Ψεκασμός ή εκνέφωση με πιστοποιημένα βιοκτόνα.' },
  { step: '04', title: 'Πιστοποίηση', desc: 'Χορηγούμε βεβαίωση απολύμανσης.' },
];
const faqs = [
  { q: 'Πότε χρειάζεται απολύμανση χώρου;', a: 'Η απολύμανση συνιστάται μετά από ασθένεια, σε χώρους υγειονομικού ενδιαφέροντος, σε ξενοδοχεία, εστιατόρια, γραφεία, αλλά και σε κατοικίες μετά από πλημμύρα ή μακρά απουσία.' },
  { q: 'Είναι ασφαλή τα σκευάσματα;', a: 'Ναι, χρησιμοποιούμε αποκλειστικά εγκεκριμένα βιοκτόνα χαμηλής τοξικότητας, ασφαλή για ανθρώπους και κατοικίδια.' },
  { q: 'Πόσο γρήγορα μπορώ να χρησιμοποιήσω τον χώρο;', a: 'Συνήθως μετά από 1-2 ώρες αερισμού. Θα σας ενημερώσουμε αναλυτικά.' },
];
---
<ServiceLayout title="Απολυμάνσεις" description="Επαγγελματικές απολυμάνσεις χώρων σε Πειραιά και Δυτική Αττική. Πιστοποιημένα βιοκτόνα, βεβαίωση απολύμανσης." heroTitle="Επαγγελματικές Απολυμάνσεις Χώρων" heroSubtitle="Ολοκληρωμένη απολύμανση κατά μικροβίων, ιών και βακτηρίων. Πιστοποιημένες μέθοδοι, βεβαίωση εφαρμογής." features={features} process={process} faqs={faqs}>
  <h2>Απολύμανση για Κάθε Χώρο</h2>
  <p>Η BioClean Pro παρέχει υπηρεσίες απολύμανσης σε κατοικίες, καταστήματα, γραφεία, εστιατόρια, ξενοδοχεία, σχολεία και νοσοκομεία. Εφαρμόζουμε πρωτόκολλα απολύμανσης σύμφωνα με τις οδηγίες του ΕΟΔΥ.</p>
  <h3>Μέθοδοι Απολύμανσης</h3>
  <ul>
    <li><strong>Ψεκασμός ULV:</strong> Υπερμικροσταγονίδια που καλύπτουν κάθε επιφάνεια</li>
    <li><strong>Εκνέφωση (Fogging):</strong> Ιδανικό για μεγάλους χώρους και αεραγωγούς</li>
    <li><strong>Επιφανειακή Απολύμανση:</strong> Στοχευμένος καθαρισμός κρίσιμων σημείων επαφής</li>
  </ul>
  <p>Μετά την ολοκλήρωση, χορηγούμε επίσημη βεβαίωση απολύμανσης που μπορείτε να χρησιμοποιήσετε για τις ανάγκες σας.</p>
</ServiceLayout>
