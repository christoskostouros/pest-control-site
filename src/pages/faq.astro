---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  { q: 'Πόσο κοστίζει μια απεντόμωση;', a: 'Το κόστος εξαρτάται από τον τύπο εντόμου, τη μέθοδο αντιμετώπισης και το μέγεθος του χώρου. Ενδεικτικά, μια απεντόμωση κατοικίας ξεκινά από 40-60€. Προσφέρουμε δωρεάν εκτίμηση χωρίς δέσμευση.' },
  { q: 'Είναι ασφαλή τα σκευάσματα για παιδιά και κατοικίδια;', a: 'Ναι. Χρησιμοποιούμε αποκλειστικά πιστοποιημένα βιοκτόνα εγκεκριμένα από τον ΕΟΦ, με χαμηλή τοξικότητα. Τα gel είναι τοποθετημένα σε σημεία μη προσβάσιμα σε παιδιά και κατοικίδια.' },
  { q: 'Χρειάζεται να αδειάσω το σπίτι;', a: 'Στις περισσότερες μεθόδους (gel, μικροψεκασμός) δεν χρειάζεται. Σε ψεκασμούς μεγάλης κλίμακας ή εκνεφώσεις, μπορεί να χρειαστεί βραχεία απομάκρυνση 1-2 ωρών. Θα σας ενημερώσουμε εκ των προτέρων.' },
  { q: 'Πόσο διαρκεί μια τυπική απεντόμωση;', a: 'Μια τυπική εφαρμογή σε διαμέρισμα ολοκληρώνεται σε 30-60 λεπτά. Σε μεγαλύτερους χώρους ή σοβαρές μολύνσεις μπορεί να χρειαστούν 1-2 ώρες.' },
  { q: 'Πόσο γρήγορα βλέπω αποτέλεσμα;', a: 'Με gel εφαρμογή, ορατή μείωση σε 48 ώρες. Με ψεκασμό, τα αποτελέσματα είναι σχεδόν άμεσα. Η πλήρης εξάλειψη ολοκληρώνεται σε 1-2 εβδομάδες.' },
  { q: 'Τι εγγύηση προσφέρετε;', a: 'Προσφέρουμε εγγύηση αποτελέσματος. Αν το πρόβλημα επανεμφανιστεί εντός της περιόδου εγγύησης (ανάλογα με την υπηρεσία), πραγματοποιούμε δωρεάν επανεφαρμογή.' },
  { q: 'Δουλεύετε Σαββατοκύριακο;', a: 'Ναι, εξυπηρετούμε 7 ημέρες την εβδομάδα. Για επείγοντα, παρέχουμε αυθημερόν εξυπηρέτηση.' },
  { q: 'Σε ποιες περιοχές εξυπηρετείτε;', a: 'Εξυπηρετούμε Πειραιά, Νίκαια, Κορυδαλλό, Κερατσίνι, Αιγάλεω, Πέραμα και ολόκληρη τη Δυτική Αττική.' },
  { q: 'Χρειάζεται σύμβαση;', a: 'Όχι. Μπορείτε να ζητήσετε μεμονωμένη εφαρμογή. Ωστόσο, για επιχειρήσεις εστίασης και ξενοδοχεία, προσφέρουμε ετήσια προγράμματα τακτικής συντήρησης με ελκυστικές τιμές.' },
  { q: 'Πώς μπορώ να κλείσω ραντεβού;', a: 'Καλέστε μας στο 210 123 4567, στείλτε μήνυμα μέσω της φόρμας επικοινωνίας, ή WhatsApp. Απαντάμε εντός 30 λεπτών.' },
  { q: 'Χορηγείτε βεβαίωση απολύμανσης;', a: 'Ναι. Μετά από κάθε απολύμανση χορηγούμε επίσημη βεβαίωση εφαρμογής, η οποία μπορεί να χρησιμοποιηθεί για υγειονομικούς ελέγχους.' },
  { q: 'Είναι επικίνδυνα τα φάρμακα απεντόμωσης;', a: 'Τα σύγχρονα εντομοκτόνα που χρησιμοποιούμε είναι πολύ πιο ασφαλή από τα παλαιότερα. Είναι εγκεκριμένα από τον ΕΟΦ, χαμηλής τοξικότητας, και αποσυντίθενται γρήγορα. Ωστόσο, πρέπει πάντα να εφαρμόζονται από πιστοποιημένους τεχνικούς.' },
];
---
<BaseLayout title="Συχνές Ερωτήσεις (FAQ)" description="Απαντήσεις στις πιο συχνές ερωτήσεις για απεντομώσεις, απολυμάνσεις, κόστος, ασφάλεια σκευασμάτων, χρόνο εφαρμογής.">
  <section class="section" style="background: linear-gradient(135deg, var(--color-bg), var(--color-surface-2))">
    <div class="container" style="max-width: var(--content-default)">
      <span class="section-label">FAQ</span>
      <h1 style="font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-4)">Συχνές Ερωτήσεις</h1>
      <p style="font-size: var(--text-lg); color: var(--color-text-muted); margin-bottom: var(--space-10)">Βρείτε απαντήσεις στα πιο συνηθισμένα ερωτήματα σχετικά με τις υπηρεσίες μας.</p>
      <div style="display: flex; flex-direction: column; gap: var(--space-3)">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-q">{faq.q}</summary>
            <p class="faq-a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }
  .faq-item[open] { border-color: var(--color-primary); }
  .faq-q {
    padding: var(--space-4) var(--space-5);
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-size: var(--text-lg);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-q::after { content: '−'; }
  .faq-a {
    padding: 0 var(--space-5) var(--space-5);
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: var(--text-sm);
  }
</style>
