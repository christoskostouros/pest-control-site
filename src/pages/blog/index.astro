---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Blog - Χρήσιμα Άρθρα" description="Εκπαιδευτικά άρθρα για απεντομώσεις, κοριούς, κατσαρίδες, απολυμάνσεις. Πρακτικές συμβουλές και πληροφορίες.">
  <section class="section" style="background: linear-gradient(135deg, var(--color-bg), var(--color-surface-2))">
    <div class="container">
      <div style="text-align:center; margin-bottom: var(--space-12)">
        <span class="section-label" style="justify-content:center">Blog</span>
        <h1 style="font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-4)">Χρήσιμα Άρθρα & Οδηγοί</h1>
        <p class="section-subtitle" style="margin-inline:auto">Πρακτικές πληροφορίες για απεντομώσεις, κοριούς, κατσαρίδες, απολυμάνσεις και πρόληψη.</p>
      </div>
      <div class="blog-grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="blog-card reveal">
            <div class="blog-card-meta">
              <span class="blog-category">{post.data.category}</span>
              <time datetime={post.data.date.toISOString().split('T')[0]}>
                {post.data.date.toLocaleDateString('el-GR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <span class="blog-card-link">
              Διαβάστε Περισσότερα
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }
  .blog-card {
    display: flex; flex-direction: column; gap: var(--space-3);
    padding: var(--space-6); background: var(--color-surface);
    border: 1px solid var(--color-divider); border-radius: var(--radius-xl);
    transition: all var(--transition-smooth);
  }
  .blog-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-lg); transform: translateY(-2px); }
  .blog-card-meta {
    display: flex; align-items: center; gap: var(--space-3);
    font-size: var(--text-xs); color: var(--color-text-faint);
  }
  .blog-category {
    padding: var(--space-1) var(--space-2); background: var(--color-primary-light);
    color: var(--color-primary); font-weight: 600; border-radius: var(--radius-sm);
  }
  .blog-card-title { font-size: var(--text-lg); font-weight: 700; line-height: 1.3; }
  .blog-card-desc { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.6; flex: 1; }
  .blog-card-link {
    display: inline-flex; align-items: center; gap: var(--space-1);
    font-size: var(--text-sm); font-weight: 600; color: var(--color-primary);
  }
</style>
