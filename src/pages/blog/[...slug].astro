---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="blog-post">
    <div class="container" style="max-width: var(--content-default)">
      <header class="post-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Αρχική</a><span>/</span>
          <a href="/blog/">Blog</a><span>/</span>
          <span aria-current="page">{post.data.title}</span>
        </nav>
        <div class="post-meta">
          <span class="blog-category">{post.data.category}</span>
          <time datetime={post.data.date.toISOString().split('T')[0]}>
            {post.data.date.toLocaleDateString('el-GR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-excerpt">{post.data.description}</p>
      </header>
      <div class="post-content">
        <Content />
      </div>
      <footer class="post-footer">
        <div class="post-cta">
          <h3>Χρειάζεστε Βοήθεια;</h3>
          <p>Καλέστε μας για δωρεάν εκτίμηση ή συμπληρώστε τη φόρμα επικοινωνίας.</p>
          <div style="display:flex;gap:var(--space-4);flex-wrap:wrap;margin-top:var(--space-4)">
            <a href="tel:+302101234567" class="btn btn-primary">210 123 4567</a>
            <a href="/epikoinonia/" class="btn btn-outline">Επικοινωνία</a>
          </div>
        </div>
        <a href="/blog/" style="display:inline-flex;align-items:center;gap:var(--space-2);font-weight:600;color:var(--color-primary);margin-top:var(--space-8)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Όλα τα Άρθρα
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post { padding-block: clamp(var(--space-10), 5vw, var(--space-16)); }
  .post-header { margin-bottom: var(--space-10); }
  .breadcrumb {
    display: flex; align-items: center; gap: var(--space-2);
    font-size: var(--text-xs); color: var(--color-text-faint); margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary); }
  .post-meta {
    display: flex; align-items: center; gap: var(--space-3);
    font-size: var(--text-xs); color: var(--color-text-faint); margin-bottom: var(--space-4);
  }
  .blog-category {
    padding: var(--space-1) var(--space-2); background: var(--color-primary-light);
    color: var(--color-primary); font-weight: 600; border-radius: var(--radius-sm);
    font-size: var(--text-xs);
  }
  .post-title { font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-4); }
  .post-excerpt { font-size: var(--text-lg); color: var(--color-text-muted); line-height: 1.7; }
  .post-content { line-height: 1.8; color: var(--color-text-muted); }
  .post-content :global(h2) { font-size: var(--text-xl); font-weight: 700; color: var(--color-text); margin-top: var(--space-10); margin-bottom: var(--space-4); }
  .post-content :global(h3) { font-size: var(--text-lg); font-weight: 600; color: var(--color-text); margin-top: var(--space-8); margin-bottom: var(--space-3); }
  .post-content :global(p) { margin-bottom: var(--space-4); }
  .post-content :global(ul), .post-content :global(ol) { padding-left: var(--space-6); margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); }
  .post-content :global(strong) { color: var(--color-text); font-weight: 600; }
  .post-content :global(table) { margin-bottom: var(--space-6); border: 1px solid var(--color-divider); border-radius: var(--radius-lg); overflow: hidden; }
  .post-content :global(th), .post-content :global(td) { padding: var(--space-3) var(--space-4); text-align: left; border-bottom: 1px solid var(--color-divider); }
  .post-content :global(th) { background: var(--color-surface-2); font-weight: 600; color: var(--color-text); }
  .post-footer { margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid var(--color-divider); }
  .post-cta {
    padding: var(--space-6); background: var(--color-primary-light);
    border: 1px solid var(--color-primary); border-radius: var(--radius-xl);
  }
  .post-cta h3 { font-size: var(--text-lg); font-weight: 700; margin-bottom: var(--space-2); }
  .post-cta p { color: var(--color-text-muted); }
</style>
